{
  "name": "@laplace-one/indexer",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" },
    "./core": { "types": "./dist/core.d.ts", "import": "./dist/core.js", "require": "./dist/core.cjs" }
  },
  "files": ["dist", "drizzle"],
  "bin": {
    "laplace-indexer": "./dist/bin/indexer.js",
    "laplace-indexer-api": "./dist/bin/api.js",
    "laplace-indexer-dev": "./dist/bin/dev.js",
    "laplace-reproject": "./dist/bin/reproject.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@laplace-one/registry": "*",
    "@laplace-one/sdk": "*",
    "@solana/kit": "^6.0.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0",
    "@electric-sql/pglite": "^0.2.0",
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "@laplace-one/config": "*",
    "drizzle-kit": "^0.28.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
