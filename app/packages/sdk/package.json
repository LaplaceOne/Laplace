{
  "name": "@laplace-one/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Laplace protocol on Solana",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LaplaceOne/Laplace.git",
    "directory": "app/packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./raw": {
      "types": "./dist/raw.d.ts",
      "import": "./dist/raw.js",
      "require": "./dist/raw.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "codegen": "node codama.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@laplace-one/registry": "^0.1.0",
    "@noble/hashes": "^1.8.0",
    "@solana-program/compute-budget": "^0.15.0",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.0.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.4.0",
    "@codama/renderers-js": "^2.2.0",
    "@laplace-one/config": "*",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "codama": "^1.6.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
