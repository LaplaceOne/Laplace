  "scripts": {
    "build": "tsup", "typecheck": "tsc --noEmit", "test": "vitest run", "lint": "tsc --noEmit", "prepublishOnly": "npm run build"
  },
  "devDependencies": { "@laplace-one/config": "*", "tsup": "^8.0.0", "typescript": "^5.7.3", "vitest": "^3.0.0" }
}
