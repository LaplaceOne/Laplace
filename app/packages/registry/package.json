{
  "name": "@laplace-one/registry",
  "version": "0.1.0",
  "description": "On-chain program registry and address constants for the Laplace protocol",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LaplaceOne/Laplace.git",
    "directory": "app/packages/registry"
  },
  "publishConfig": { "access": "public" },
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" } },
